# ==============================================================
# Template for .env — copy this file to ".env" and fill in values.
# Safe to commit (contains no real secrets).
# ==============================================================

# Generate one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-random-50-char-string

# True for local development, False in production
DEBUG=True

# Comma-separated hostnames, e.g. localhost,127.0.0.1,api.bookmyvenue.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Empty = local sqlite. In production use the Supabase Postgres string:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# True only in development; set False in production and list origins below
CORS_ALLOW_ALL_ORIGINS=True

# Comma-separated frontend URLs, e.g. https://bookmyvenue.com
CORS_ALLOWED_ORIGINS=

# 2Factor.in API key for sending OTP SMS (get it from 2factor.in dashboard)
TWOFACTOR_API_KEY=

# Supabase Storage (photo uploads) — Settings -> API keys in the dashboard
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=venue-photos
